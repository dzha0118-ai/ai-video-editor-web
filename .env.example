# ============================================
# AI Video Editor - 环境变量配置文件
# ============================================
# 
# 使用说明：
# 1. 复制此文件为 .env（去掉 .example 后缀）
# 2. 填入你的真实配置值
# 3. .env 文件不会被 Git 追踪（已在 .gitignore 中配置）
#
# 配置优先级（从高到低）：
#   1. 环境变量（os.environ）
#   2. 此 .env 文件
#   3. config.toml 文件
#   4. 代码默认值
#
# ⚠️  安全提醒：
#   - 不要将 .env 文件提交到 GitHub！
#   - 不要将 API Key 写入任何代码文件！
#   - 生产环境优先使用系统级环境变量
#
# ============================================

# --------------------------------------------
# 必须配置项
# --------------------------------------------

# DeepSeek API Key（必填）
# 从 https://platform.deepseek.com/api_keys 获取
# 如果不填，系统将使用用户自带 Key 模式（SaaS）
DEEPSEEK_API_KEY=sk-你的DeepSeekAPIKey

# FFmpeg 可执行文件路径（必填，除非 FFmpeg 已在系统 PATH 中）
# Windows 示例: C:/ffmpeg/bin/ffmpeg.exe
# Linux/macOS 示例: /usr/bin/ffmpeg
FFMPEG_PATH=ffmpeg

# FFprobe 可执行文件路径（FFmpeg 工具，通常在同一目录）
FFPROBE_PATH=ffprobe

# --------------------------------------------
# 可选配置项（不填则使用默认值）
# --------------------------------------------

# DeepSeek 模型设置
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.3

# Whisper 模型设置
WHISPER_MODEL=base
WHISPER_LANGUAGE=auto

# 应用配置
MAX_UPLOAD_MB=500
TEMP_CLEANUP_MIN=30
